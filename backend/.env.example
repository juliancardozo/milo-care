# Server
PORT=3001
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/milocura?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Resend (email)
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=noreply@milocura.com

# App URL (used in reset password links)
APP_URL=http://localhost:5173
