# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────
# Docker Compose (local):
MONGODB_URI=mongodb://mongo:27017/milocura
# MongoDB Atlas (producción):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/milocura?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── Resend (correo electrónico) ───────────────────────────────
#
# 1. Crear cuenta gratuita en https://resend.com
# 2. Ir a API Keys → Create API Key → copiar aquí
# 3. En desarrollo local SIN dominio propio:
#    - Usar RESEND_FROM_EMAIL=onboarding@resend.dev
#    - Solo se puede enviar al email verificado en la cuenta Resend
# 4. En producción con dominio propio:
#    - Verificar el dominio en Resend → DNS settings
#    - Usar RESEND_FROM_EMAIL=noreply@tudominio.com
#
# Si RESEND_API_KEY no está seteada el servidor arranca igual,
# pero los envíos fallarán con error en el log.
#
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── App URL (para links en emails) ───────────────────────────
APP_URL=http://localhost:5173
# URL pública específica para links de expediente veterinario compartido.
# Si no se define, usa APP_URL.
VET_SHARE_PUBLIC_BASE_URL=http://localhost:5173

# ── Billing (interés en Premium) ─────────────────────────────
# Email interno que recibe los avisos cuando un usuario pide pasarse a Premium.
# Opcional: si no se define, usa julian.cardozo.viggiano@gmail.com por defecto.
BILLING_NOTIFY_EMAIL=julian.cardozo.viggiano@gmail.com

# ── Google Wallet (pases de perfiles de perros) ──────────────
#
# 1. Crear/usar un proyecto en Google Cloud y habilitar la "Google Wallet API".
# 2. Alta en https://pay.google.com/business/console → copiar el Issuer ID.
# 3. Crear un service account con acceso a Wallet y descargar su clave JSON.
#    Codificar ese JSON en base64 y pegarlo en GOOGLE_WALLET_SA_KEY_B64:
#      base64 -i service-account.json | tr -d '\n'   (macOS/Linux)
# 4. Crear una sola vez la Generic Class corriendo:
#      node scripts/createWalletClass.js
#
# Si GOOGLE_WALLET_ENABLED no es "true", el endpoint responde 503 y la app
# arranca igual aunque falten las credenciales.
#
GOOGLE_WALLET_ENABLED=false
GOOGLE_WALLET_ISSUER_ID=
# Identificador de la Generic Class (se combina como <issuerId>.<classId>).
GOOGLE_WALLET_CLASS_ID=milo_dog_card
# Clave del service account (JSON completo en base64).
GOOGLE_WALLET_SA_KEY_B64=
# Dominio público para el QR del pase (la ficha que ve quien encuentra al perro).
# Debe ser accesible desde cualquier teléfono, NO localhost. Cae a APP_URL si se deja vacío.
# Frontend en producción: AWS Amplify.
WALLET_PUBLIC_BASE_URL=https://your-app.amplifyapp.com

# ── Notificaciones push (Web Push / VAPID) ───────────────────────────────────
# Generá tu propio par con: node -e "console.log(require('web-push').generateVAPIDKeys())"
PUSH_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hola@milocare.online

# ── Companion (B2B2C / white-label) ──────────────────────────────────────────
# Apagado por defecto: oculta (404) las rutas de partners. Las rutas de export
# PDF / compartir WhatsApp NO dependen de este flag (son premium B2C).
COMPANION_ENABLED=false
