# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────
# Docker Compose (local):
MONGODB_URI=mongodb://mongo:27017/milocura
# MongoDB Atlas (producción):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/milocura?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── Resend (correo electrónico) ───────────────────────────────
#
# 1. Crear cuenta gratuita en https://resend.com
# 2. Ir a API Keys → Create API Key → copiar aquí
# 3. En desarrollo local SIN dominio propio:
#    - Usar RESEND_FROM_EMAIL=onboarding@resend.dev
#    - Solo se puede enviar al email verificado en la cuenta Resend
# 4. En producción con dominio propio:
#    - Verificar el dominio en Resend → DNS settings
#    - Usar RESEND_FROM_EMAIL=noreply@tudominio.com
#
# Si RESEND_API_KEY no está seteada el servidor arranca igual,
# pero los envíos fallarán con error en el log.
#
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── App URL (para links en emails) ───────────────────────────
APP_URL=http://localhost:5173

# ── MercadoPago (billing de suscripciones Premium) ───────────
#
# 1. Crear aplicación en https://www.mercadopago.com.uy/developers/panel
# 2. Credenciales de prueba (sandbox): usar Access Token que empieza con TEST-
# 3. Credenciales de producción: usar Access Token que empieza con APP_USR-
#
# Para la firma del webhook:
# 4. En el panel de MP → Tus aplicaciones → Webhooks → Agregar URL
# 5. Copiar el "Secret" que genera MP y pegarlo en MP_WEBHOOK_SECRET
#
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
MP_WEBHOOK_SECRET=<secret_del_webhook_en_mp_panel>

# Configuración del plan de suscripción
MP_PLAN_REASON=Milo Care Premium
MP_PLAN_AMOUNT=299
MP_CURRENCY=UYU
